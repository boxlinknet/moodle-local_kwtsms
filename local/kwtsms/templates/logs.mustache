{{!
    @template local_kwtsms/logs

    Logs tab with filter form, table of log entries with detail rows,
    pagination, and clear/export buttons.

    Context variables required for this template:
    * filterurl string
    * search string
    * datefrom string
    * dateto string
    * statuses array [{key, label, selected}]
    * eventtypes array [{key, label, selected}]
    * hasrecords bool
    * records array [{id, timecreatedstr, phone, eventlabel, templatename,
      statuslabel, badgeclass, skipreason, credits, testmode, message,
      hasapiresponse, apiresponse, haserrorcode, errorcode}]
    * pagingbar string Rendered paging bar HTML.
    * canmanage bool

    Example context (json):
    {
        "filterurl": "/local/kwtsms/view.php?tab=logs",
        "search": "",
        "datefrom": "",
        "dateto": "",
        "statuses": [{"key":"sent","label":"Sent","selected":false}],
        "eventtypes": [{"key":"user_graded","label":"Grade Posted","selected":false}],
        "hasrecords": false,
        "records": [],
        "pagingbar": "",
        "canmanage": true
    }
}}
<div id="kwtsms-logs-feedback"></div>

<form method="get" action="{{filterurl}}" class="mb-3">
    <input type="hidden" name="tab" value="logs">
    <div class="form-row align-items-end">
        <div class="form-group col-md-2 mb-2">
            <label for="filter_status">{{#str}}log_filter_status, local_kwtsms{{/str}}</label>
            <select name="filter_status" id="filter_status" class="form-control custom-select">
                <option value="">{{#str}}log_filter_all, local_kwtsms{{/str}}</option>
                {{#statuses}}
                    <option value="{{key}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                {{/statuses}}
            </select>
        </div>

        <div class="form-group col-md-2 mb-2">
            <label for="filter_event">{{#str}}log_filter_event, local_kwtsms{{/str}}</label>
            <select name="filter_event" id="filter_event" class="form-control custom-select">
                <option value="">{{#str}}log_filter_all, local_kwtsms{{/str}}</option>
                {{#eventtypes}}
                    <option value="{{key}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                {{/eventtypes}}
            </select>
        </div>

        <div class="form-group col-md-2 mb-2">
            <label for="filter_search">{{#str}}log_filter_search, local_kwtsms{{/str}}</label>
            <input type="text" name="filter_search" id="filter_search" class="form-control"
                   value="{{search}}"
                   placeholder="{{#str}}log_filter_search, local_kwtsms{{/str}}">
        </div>

        <div class="form-group col-md-2 mb-2">
            <label for="filter_date_from">{{#str}}log_filter_from, local_kwtsms{{/str}}</label>
            <input type="date" name="filter_date_from" id="filter_date_from" class="form-control" value="{{datefrom}}">
        </div>

        <div class="form-group col-md-2 mb-2">
            <label for="filter_date_to">{{#str}}log_filter_to, local_kwtsms{{/str}}</label>
            <input type="date" name="filter_date_to" id="filter_date_to" class="form-control" value="{{dateto}}">
        </div>

        <div class="form-group col-md-2 mb-2">
            <button type="submit" class="btn btn-primary btn-block">{{#str}}log_filter_btn, local_kwtsms{{/str}}</button>
        </div>
    </div>
</form>

{{^hasrecords}}
    <div class="alert alert-info">{{#str}}log_no_records, local_kwtsms{{/str}}</div>
{{/hasrecords}}

{{#hasrecords}}
    <div class="table-responsive">
        <table class="table table-striped table-hover" id="kwtsms-logs-table">
            <thead>
                <tr>
                    <th>{{#str}}log_date, local_kwtsms{{/str}}</th>
                    <th>{{#str}}log_phone, local_kwtsms{{/str}}</th>
                    <th>{{#str}}log_event, local_kwtsms{{/str}}</th>
                    <th>{{#str}}log_template, local_kwtsms{{/str}}</th>
                    <th>{{#str}}log_status, local_kwtsms{{/str}}</th>
                    <th>{{#str}}log_reason, local_kwtsms{{/str}}</th>
                    <th>{{#str}}log_credits, local_kwtsms{{/str}}</th>
                    <th>{{#str}}log_test_mode, local_kwtsms{{/str}}</th>
                    <th>{{#str}}log_details, local_kwtsms{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#records}}
                    <tr>
                        <td>{{timecreatedstr}}</td>
                        <td>{{phone}}</td>
                        <td>{{eventlabel}}</td>
                        <td>{{templatename}}</td>
                        <td><span class="badge {{badgeclass}}">{{statuslabel}}</span></td>
                        <td>{{skipreason}}</td>
                        <td>{{credits}}</td>
                        <td>
                            {{#testmode}}<span class="badge badge-warning">{{#str}}yes{{/str}}</span>{{/testmode}}
                            {{^testmode}}<span class="badge badge-light">{{#str}}no{{/str}}</span>{{/testmode}}
                        </td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-secondary kwtsms-log-details-btn" data-log-id="{{id}}">
                                {{#str}}log_details, local_kwtsms{{/str}}
                            </button>
                        </td>
                    </tr>
                    <tr class="kwtsms-log-detail-row d-none" id="kwtsms-detail-{{id}}">
                        <td colspan="9">
                            <div class="p-3 bg-light border rounded">
                                <h6>{{#str}}log_message, local_kwtsms{{/str}}</h6>
                                <pre class="mb-3">{{message}}</pre>
                                {{#hasapiresponse}}
                                    <h6>{{#str}}log_api_response, local_kwtsms{{/str}}</h6>
                                    <pre class="mb-3">{{apiresponse}}</pre>
                                {{/hasapiresponse}}
                                {{#haserrorcode}}
                                    <h6>{{#str}}log_error_code, local_kwtsms{{/str}}</h6>
                                    <p><code>{{errorcode}}</code></p>
                                {{/haserrorcode}}
                            </div>
                        </td>
                    </tr>
                {{/records}}
            </tbody>
        </table>
    </div>
    {{{pagingbar}}}
{{/hasrecords}}

<div class="mt-3">
    {{#canmanage}}
        <button type="button" id="kwtsms-clear-logs-btn" class="btn btn-outline-danger mr-2">{{#str}}log_clear, local_kwtsms{{/str}}</button>
    {{/canmanage}}
    <button type="button" id="kwtsms-export-logs-btn" class="btn btn-outline-primary">{{#str}}log_export, local_kwtsms{{/str}}</button>
</div>

