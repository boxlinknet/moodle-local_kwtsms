{{!
    @template local_kwtsms/integrations

    Event notification toggles: student events and admin alerts.

    Context variables required for this template:
    * formaction string Form POST URL.
    * sesskey string Session key.
    * studentevents array [{key, label, desc, enabled}]
    * adminevents array [{key, label, desc, enabled}]

    Example context (json):
    {
        "formaction": "/local/kwtsms/view.php?tab=integrations",
        "sesskey": "abc123",
        "studentevents": [{"key":"user_graded","label":"Grade Posted","desc":"Send SMS when a grade is posted.","enabled":true}],
        "adminevents": [{"key":"user_created","label":"New User","desc":"Alert admin on new user.","enabled":false}]
    }
}}
<p class="text-muted mb-4">{{#str}}integrations_desc, local_kwtsms{{/str}}</p>

<form method="post" action="{{formaction}}" class="mform">
    <input type="hidden" name="sesskey" value="{{sesskey}}">

    <h4>{{#str}}student_notifications, local_kwtsms{{/str}}</h4>

    {{#studentevents}}
        <div class="form-group row mb-3">
            <div class="col-sm-3">
                <label for="id_event_{{key}}">{{label}}</label>
            </div>
            <div class="col-sm-9">
                <input type="hidden" name="event_{{key}}" value="0">
                <input type="checkbox" name="event_{{key}}" id="id_event_{{key}}" value="1" {{#enabled}}checked{{/enabled}}>
                <small class="form-text text-muted">{{desc}}</small>
            </div>
        </div>
    {{/studentevents}}

    <h4 class="mt-4">{{#str}}admin_alerts, local_kwtsms{{/str}}</h4>

    {{#adminevents}}
        <div class="form-group row mb-3">
            <div class="col-sm-3">
                <label for="id_event_{{key}}">{{label}}</label>
            </div>
            <div class="col-sm-9">
                <input type="hidden" name="event_{{key}}" value="0">
                <input type="checkbox" name="event_{{key}}" id="id_event_{{key}}" value="1" {{#enabled}}checked{{/enabled}}>
                <small class="form-text text-muted">{{desc}}</small>
            </div>
        </div>
    {{/adminevents}}

    <div class="form-group row mb-3">
        <div class="col-sm-9 offset-sm-3">
            <button type="submit" class="btn btn-primary">{{#str}}savechanges{{/str}}</button>
        </div>
    </div>
</form>
